{
  "name": "wedding-photo-share",
  "version": "0.1.0",
  "bin": {
    "wedding-photo-share": "bin/wedding-photo-share.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "npm run build && cdk deploy --profile yyl --outputs-file cdk-outputs.json --require-approval never",
    "destroy": "cdk destroy --profile yyl --force",
    "test": "npm run test:unit -- --runInBand",
    "test:fast": "npm run test:unit -- --runInBand",
    "test:unit": "jest --watchman=false",
    "test:unit:watch": "jest --watch",
    "clean": "rimraf \"{bin,lambda,lib}/**/*.{js,d.ts}\" cdk-outputs.json"
  },
  "devDependencies": {
    "@aws-cdk/aws-amplify-alpha": "^2.248.0-alpha.0",
    "@types/aws-lambda": "^8.10.152",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.12.0",
    "aws-cdk": "^2.1112.0",
    "jest": "29.7.0",
    "ts-jest": "29.4.11",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1014.0",
    "@aws-sdk/client-cloudfront": "^3.870.0",
    "@aws-sdk/client-dynamodb": "^3.870.0",
    "@aws-sdk/client-s3": "^3.870.0",
    "@aws-sdk/client-secrets-manager": "^3.870.0",
    "@aws-sdk/cloudfront-signer": "^3.870.0",
    "@aws-sdk/lib-dynamodb": "^3.870.0",
    "@aws-sdk/s3-request-presigner": "^3.1055.0",
    "aws-cdk-lib": "2.250.0",
    "bcryptjs": "^2.4.3",
    "constructs": "^10.5.1",
    "esbuild": "^0.28.0",
    "jest-util": "^29.7.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1"
  }
}
